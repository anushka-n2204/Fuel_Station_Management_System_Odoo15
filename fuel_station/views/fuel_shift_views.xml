<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FUEL SHIFT — List, Form, Kanban, Search, Action
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- List view -->
    <record id="fuel_shift_view_list" model="ir.ui.view">
        <field name="name">fuel.shift.list</field>
        <field name="model">fuel.shift</field>
        <field name="arch" type="xml">
            <tree string="Shifts"
                  decoration-info="state == 'open'"
                  decoration-success="state == 'closed'"
                  decoration-muted="state == 'locked'">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="opening_time" string="Opened"/>
                <field name="closing_time" string="Closed"/>
                <field name="total_litres" string="Litres" sum="Total Litres"/>
                <field name="total_revenue" string="Revenue" sum="Total Revenue"/>
                <field name="total_expenses" string="Expenses" sum="Total Expenses"/>
                <field name="net_cash" string="Net Cash" sum="Net Cash"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-info="state == 'open'"
                       decoration-success="state == 'closed'"
                       decoration-primary="state == 'locked'"/>
            </tree>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="fuel_shift_view_kanban" model="ir.ui.view">
        <field name="name">fuel.shift.kanban</field>
        <field name="model">fuel.shift</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="total_revenue"/>
                <field name="net_cash"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle">
                                        <field name="date"/> — <field name="employee_id"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>Revenue: <strong><field name="total_revenue"/></strong></div>
                                <div>Net Cash: <strong><field name="net_cash"/></strong></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form view -->
    <record id="fuel_shift_view_form" model="ir.ui.view">
        <field name="name">fuel.shift.form</field>
        <field name="model">fuel.shift</field>
        <field name="arch" type="xml">
            <form string="Fuel Shift">
                <header>
                    <!-- State workflow buttons -->
                    <button name="action_open_shift" string="Open Shift"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_close_shift" string="Close Shift"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'open')]}"/>
                    <button name="action_lock_shift" string="Lock"
                            type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'closed')]}"/>
                    <!-- State bar -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,open,closed,locked"/>
                </header>
                <sheet>
                    <!-- Smart button: Sales -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sales" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                attrs="{'invisible': [('sale_count', '=', 0)]}">
                            <field name="sale_count" widget="statinfo" string="Sales"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Shift Info">
                            <field name="employee_id"/>
                            <field name="date"/>
                        </group>
                        <group string="Timestamps">
                            <field name="opening_time" readonly="1"/>
                            <field name="closing_time" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab 1: Nozzle Readings -->
                        <page string="Nozzle Readings" name="readings">
                            <field name="shift_line_ids"
                                   attrs="{'readonly': [('state', 'in', ['closed', 'locked'])]}">
                                <tree editable="bottom">
                                    <field name="nozzle_id"/>
                                    <field name="pump_id" readonly="1"/>
                                    <field name="fuel_type_id" readonly="1"/>
                                    <field name="opening_meter" readonly="1"/>
                                    <field name="closing_meter"
                                           attrs="{'readonly': [('shift_id.state', '!=', 'open')]}"/>
                                    <field name="litres_sold" readonly="1" sum="Total Litres"/>
                                    <field name="price_per_litre" readonly="1"/>
                                    <field name="revenue" readonly="1" sum="Total Revenue"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 2: Expenses -->
                        <page string="Expenses" name="expenses">
                            <field name="expense_ids"
                                   attrs="{'readonly': [('state', 'in', ['closed', 'locked'])]}">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="expense_type"/>
                                    <field name="description"/>
                                    <field name="amount" sum="Total"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 3: Sales (read-only, auto-created) -->
                        <page string="Sales" name="sales"
                              attrs="{'invisible': [('state', 'in', ['draft', 'open'])]}">
                            <field name="sale_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="nozzle_id"/>
                                    <field name="fuel_type_id"/>
                                    <field name="litres_sold"/>
                                    <field name="price_per_litre"/>
                                    <field name="subtotal" sum="Total"/>
                                    <field name="payment_method"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 4: Notes -->
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Manager remarks…"/>
                        </page>
                    </notebook>

                    <!-- Footer totals -->
                    <group class="oe_subtotal_footer oe_right">
                        <field name="total_litres" string="Total Litres" readonly="1"/>
                        <field name="total_revenue" string="Total Revenue" readonly="1"/>
                        <field name="total_expenses" string="Total Expenses" readonly="1"/>
                        <div class="oe_subtotal_footer_separator">
                            <label for="net_cash"/>
                        </div>
                        <field name="net_cash" nolabel="1" class="oe_subtotal_footer_separator" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="fuel_shift_view_search" model="ir.ui.view">
        <field name="name">fuel.shift.search</field>
        <field name="model">fuel.shift</field>
        <field name="arch" type="xml">
            <search string="Shifts">
                <field name="name" string="Reference"/>
                <field name="employee_id"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="open" string="Open" domain="[('state','=','open')]"/>
                <filter name="closed" string="Closed" domain="[('state','=','closed')]"/>
                <filter name="locked" string="Locked" domain="[('state','=','locked')]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_month" string="This Month"
                        domain="[('date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee"
                            context="{'group_by':'employee_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by':'date:day'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_fuel_shift" model="ir.actions.act_window">
        <field name="name">Shifts</field>
        <field name="res_model">fuel.shift</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Start a new shift
            </p>
            <p>Create a shift, open it to auto-populate nozzle readings,
               then close it to record sales and update tank stock.</p>
        </field>
    </record>

</odoo>
