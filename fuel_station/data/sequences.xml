<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══ Fuel Shift sequence ══════════════════════════════════════════ -->
        <record id="seq_fuel_shift" model="ir.sequence">
            <field name="name">Fuel Shift</field>
            <field name="code">fuel.shift</field>
            <field name="prefix">SHIFT/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- ══ Fuel Sale sequence ════════════════════════════════════════════ -->
        <record id="seq_fuel_sale" model="ir.sequence">
            <field name="name">Fuel Sale</field>
            <field name="code">fuel.sale</field>
            <field name="prefix">SALE/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- ══ Fuel Purchase sequence ════════════════════════════════════════ -->
        <record id="seq_fuel_purchase" model="ir.sequence">
            <field name="name">Fuel Purchase</field>
            <field name="code">fuel.purchase</field>
            <field name="prefix">FPURCH/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
