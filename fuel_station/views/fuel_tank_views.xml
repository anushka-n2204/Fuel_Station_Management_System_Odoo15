<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FUEL TANK — List, Form, Search, Action
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- List view -->
    <record id="fuel_tank_view_list" model="ir.ui.view">
        <field name="name">fuel.tank.list</field>
        <field name="model">fuel.tank</field>
        <field name="arch" type="xml">
            <tree string="Fuel Tanks"
                  decoration-danger="stock_status == 'critical'"
                  decoration-warning="stock_status == 'low'"
                  decoration-muted="not active">
                <field name="name"/>
                <field name="fuel_type_id"/>
                <field name="location"/>
                <field name="capacity" string="Capacity (L)"/>
                <field name="current_stock" string="Stock (L)"/>
                <field name="stock_percentage" string="Stock %" widget="progressbar"/>
                <field name="stock_status" widget="badge"
                       decoration-success="stock_status == 'ok'"
                       decoration-warning="stock_status == 'low'"
                       decoration-danger="stock_status == 'critical'"
                       decoration-info="stock_status == 'overfull'"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="fuel_tank_view_form" model="ir.ui.view">
        <field name="name">fuel.tank.form</field>
        <field name="model">fuel.tank</field>
        <field name="arch" type="xml">
            <form string="Fuel Tank">
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Tank A"/></h1>
                    </div>
                    <group>
                        <group string="Tank Details">
                            <field name="fuel_type_id"/>
                            <field name="location"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Stock Levels">
                            <field name="capacity"/>
                            <field name="current_stock"/>
                            <field name="min_level" string="Minimum Level (L)"/>
                            <field name="stock_percentage" widget="progressbar"/>
                            <field name="stock_status" widget="badge"
                                   decoration-success="stock_status == 'ok'"
                                   decoration-warning="stock_status == 'low'"
                                   decoration-danger="stock_status == 'critical'"
                                   decoration-info="stock_status == 'overfull'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="fuel_tank_view_search" model="ir.ui.view">
        <field name="name">fuel.tank.search</field>
        <field name="model">fuel.tank</field>
        <field name="arch" type="xml">
            <search string="Fuel Tanks">
                <field name="name" string="Tank Name"/>
                <field name="fuel_type_id"/>
                <filter name="low" string="Low Stock"
                        domain="[('stock_status','in',['low','critical'])]"/>
                <filter name="critical" string="Critical"
                        domain="[('stock_status','=','critical')]"/>
                <filter name="active" string="Active"
                        domain="[('active','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_fuel" string="Fuel Type"
                            context="{'group_by':'fuel_type_id'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by':'stock_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_fuel_tank" model="ir.actions.act_window">
        <field name="name">Fuel Tanks</field>
        <field name="res_model">fuel.tank</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first underground tank
            </p>
            <p>Define the underground storage tanks at your station. Each tank
               holds one fuel type and its stock is updated automatically when
               purchases are delivered.</p>
        </field>
    </record>

</odoo>
