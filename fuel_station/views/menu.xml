<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         TOP-LEVEL APP MENU
         ══════════════════════════════════════════════════════════════════════ -->

    <menuitem id="menu_fuel_station_root"
