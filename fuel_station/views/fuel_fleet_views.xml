<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FUEL FLEET — List, Form, Search, Action
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- List view -->
    <record id="fuel_fleet_view_list" model="ir.ui.view">
        <field name="name">fuel.fleet.list</field>
        <field name="model">fuel.fleet</field>
        <field name="arch" type="xml">
            <tree string="Fleet Accounts"
                  decoration-danger="credit_balance &lt; 0"
                  decoration-warning="credit_balance &lt; (credit_limit * 0.2)"
                  decoration-muted="state != 'active'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="vehicle_reg" string="Vehicle Reg"/>
                <field name="fuel_type_id"/>
                <field name="credit_limit" string="Limit"/>
                <field name="credit_used" string="Used"/>
                <field name="credit_balance" string="Balance"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'suspended'"
                       decoration-danger="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="fuel_fleet_view_form" model="ir.ui.view">
        <field name="name">fuel.fleet.form</field>
        <field name="model">fuel.fleet</field>
        <field name="arch" type="xml">
            <form string="Fleet Account">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,suspended,closed"/>
                </header>
                <sheet>
                    <!-- Smart button: Credit Sales -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sales" type="object"
                                class="oe_stat_button" icon="fa-fire"
                                attrs="{'invisible': [('sale_count', '=', 0)]}">
                            <field name="sale_count" widget="statinfo"
                                   string="Credit Sales"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. ABC Transport Ltd"/></h1>
                    </div>

                    <group>
                        <group string="Account Details">
                            <field name="partner_id"/>
                            <field name="vehicle_reg"/>
                            <field name="fuel_type_id"/>
                        </group>
                        <group string="Credit">
                            <field name="credit_limit"/>
                            <field name="credit_used" readonly="1"/>
                            <field name="credit_balance" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Credit Sales" name="sales">
                            <field name="sale_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="shift_id"/>
                                    <field name="fuel_type_id"/>
                                    <field name="litres_sold" string="Litres"/>
                                    <field name="subtotal" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Account notes…"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="fuel_fleet_view_search" model="ir.ui.view">
        <field name="name">fuel.fleet.search</field>
        <field name="model">fuel.fleet</field>
        <field name="arch" type="xml">
            <search string="Fleet Accounts">
                <field name="name" string="Account Name"/>
                <field name="partner_id"/>
                <field name="vehicle_reg"/>
                <field name="fuel_type_id"/>
                <filter name="active" string="Active"
                        domain="[('state','=','active')]"/>
                <filter name="suspended" string="Suspended"
                        domain="[('state','=','suspended')]"/>
                <filter name="low_balance" string="Low Balance"
                        domain="[('credit_balance','&lt;', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_fuel" string="Fuel Type"
                            context="{'group_by':'fuel_type_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_fuel_fleet" model="ir.actions.act_window">
        <field name="name">Fleet Accounts</field>
        <field name="res_model">fuel.fleet</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first fleet customer
            </p>
            <p>Fleet accounts allow corporate customers to receive fuel on credit.
               Their balance updates automatically as credit sales are recorded.</p>
        </field>
    </record>

</odoo>
